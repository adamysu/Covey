COMPOSE_PROJECT_NAME=covey

# Database
POSTGRES_DB=covey
POSTGRES_USER=covey
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://covey:replace-with-a-long-random-password@postgres:5432/covey

# Public ports on the host/server
API_HOST_PORT=8080
WEB_PORT=3000

# Internal API container port. Usually leave this at 8080.
API_PORT=8080

# The browser-facing API URL. For a LAN server, use the server IP or DNS name.
# Example: http://192.168.1.25:8080
PUBLIC_API_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:3000

# Sessions/security
SESSION_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECURE=false

# Cameras/go2rtc
GO2RTC_IMAGE=alexxit/go2rtc:latest
GO2RTC_URL=http://go2rtc:1984
GO2RTC_PUBLIC_URL=http://localhost:1984
GO2RTC_PLAYBACK_MODE=mse
GO2RTC_BIND=127.0.0.1
GO2RTC_PORT=1984
GO2RTC_WEBRTC_BIND=127.0.0.1
GO2RTC_WEBRTC_PORT=8555
GO2RTC_WEBRTC_CANDIDATE=127.0.0.1:8555
GO2RTC_WEBRTC_LISTEN=:8555/tcp

# Backups/uploads inside the API container.
# Docker volumes persist these paths by default.
BACKUP_DIR=/app/backups
UPLOAD_DIR=/app/uploads
BACKUP_SCHEDULE_CHECK_MS=3600000

# Optional prebuilt images. Used with docker-compose.registry.yml.
COVEY_API_IMAGE=ghcr.io/your-user/covey-api:latest
COVEY_WEB_IMAGE=ghcr.io/your-user/covey-web:latest
