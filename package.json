{
  "name": "covey",
  "private": true,
  "version": "0.1.0",
  "description": "Deployable Covey quail flock manager",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "db:migrate": "docker compose run --rm api npm run db:migrate",
    "db:studio": "docker compose run --rm api npm run db:studio",
    "test": "npm --workspaces test",
    "lint": "npm --workspaces run lint --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
